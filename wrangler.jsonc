{
	"compatibility_date": "2025-10-08",
	"main": "src/index.ts",
	"name": "chanfana-openapi-template",
	"upload_source_maps": true,
	"triggers": {
		// Türkiye saati (UTC+3): 06:00 ve 19:00
		// UTC karşılıkları: 03:00 ve 16:00
		"crons": ["0 3 * * *", "0 16 * * *"]
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "openapi-template-db",
			"database_id": "4cfc963a-e357-4ef7-ad3b-f7024f496a03"
		}
	]
}
